:root {
    --bg-main: #0a0c15;
    --card-bg: rgba(22, 27, 45, 0.85);
    --card-bg-solid: #161b2d;
    --row-alt: #1c2236;
    --accent-blue: #00d2ff;
    --accent-purple: #7b61ff;
    --accent-gradient: linear-gradient(135deg, #00d2ff 0%, #7b61ff 100%);
    --text-primary: #f0f2f5;
    --text-muted: #8892a4;
    --error-red: #ff4d6d;
    --success-green: #10b981;
    --border-subtle: rgba(255, 255, 255, 0.06);
    --glow-blue: rgba(0, 210, 255, 0.35);
    --glow-purple: rgba(123, 97, 255, 0.25);
}

/* ─── Global ─── */
body {
    background-color: var(--bg-main);
    background-image:
        radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0, 210, 255, 0.06) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 100%, rgba(123, 97, 255, 0.05) 0%, transparent 60%);
    color: var(--text-primary);
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 0;
    min-height: 100vh;
}

::selection {
    background: var(--accent-blue);
    color: #000;
}

/* ─── Glassmorphism Card Container ─── */
.glass-card {
    background: var(--card-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.45),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    padding: 2.5rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
}

.glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    border-radius: 20px 20px 0 0;
}

/* ─── Form Labels ─── */
.form-label {
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.4rem;
}

/* ─── Form Controls ─── */
.form-control, .form-select {
    background: rgba(30, 36, 56, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #fff !important;
    border-radius: 10px;
    padding: 0.65rem 1rem;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.form-control:focus, .form-select:focus {
    background: rgba(38, 45, 68, 0.95);
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px var(--glow-blue), 0 0 20px rgba(0, 210, 255, 0.1);
    outline: none;
}

.form-control::placeholder {
    color: rgba(255, 255, 255, 0.25);
    font-style: italic;
}

.form-select option {
    background: #1e2438;
    color: #fff;
}

/* ─── Section Divider ─── */
.section-divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
    margin: 1.5rem 0;
}

/* ─── Form Section Header ─── */
.form-section-title {
    color: var(--accent-blue);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.form-section-title i {
    font-size: 1rem;
    opacity: 0.8;
}

/* ─── Validation Message Styling ─── */
.text-danger {
    color: var(--error-red) !important;
    font-size: 0.8rem;
    font-weight: 500;
}

.validation-summary-errors ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.validation-summary-errors ul li {
    background: rgba(255, 77, 109, 0.1);
    border: 1px solid rgba(255, 77, 109, 0.25);
    border-radius: 8px;
    padding: 0.6rem 1rem;
    margin-bottom: 0.4rem;
    font-size: 0.85rem;
}

/* ─── Buttons ─── */
.btn-grad {
    background: var(--accent-gradient);
    border: none;
    color: white !important;
    font-weight: 700;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 10px;
    padding: 12px 32px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 0.85rem;
    position: relative;
    overflow: hidden;
}

.btn-grad::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.btn-grad:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px var(--glow-blue), 0 4px 12px var(--glow-purple);
    filter: brightness(1.1);
}

.btn-grad:hover::after {
    opacity: 1;
}

.btn-grad:active {
    transform: translateY(-1px);
}

.btn-outline-light {
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-muted) !important;
    border-radius: 10px;
    padding: 12px 28px;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 1px;
    transition: all 0.3s ease;
}

.btn-outline-light:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff !important;
}

.btn-outline-danger {
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-outline-danger:hover {
    box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
    transform: translateY(-1px);
}

/* ─── Page Heading ─── */
.page-heading {
    font-weight: 800;
    letter-spacing: 3px;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 1.8rem;
}

/* ─── Table: Professional Dashboard Layout ─── */
.table-custom {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 8px;
}

.table-custom thead th {
    color: var(--text-muted);
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 14px 20px;
    border: none;
    background: transparent;
    position: relative;
}

.table-custom thead th::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20px;
    right: 20px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent-blue), transparent);
    opacity: 0.3;
}

.table-custom tbody td {
    padding: 16px 20px;
    vertical-align: middle;
    border: none;
    font-size: 0.92rem;
}

.table-custom tbody tr:nth-child(odd) {
    background-color: var(--card-bg-solid);
}

.table-custom tbody tr:nth-child(even) {
    background-color: var(--row-alt);
}

.table-custom tbody tr {
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    border-left: 3px solid transparent;
    border-radius: 10px;
}

.table-custom tbody tr:hover {
    background-color: rgba(0, 210, 255, 0.05) !important;
    border-left: 3px solid var(--accent-blue);
    transform: translateX(4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
}

.table-custom tbody tr td:first-child {
    border-radius: 10px 0 0 10px;
}

.table-custom tbody tr td:last-child {
    border-radius: 0 10px 10px 0;
}

/* ─── Custom Badge ─── */
.badge-course {
    background: linear-gradient(135deg, rgba(0, 210, 255, 0.12) 0%, rgba(123, 97, 255, 0.12) 100%);
    color: var(--accent-blue);
    border: 1px solid rgba(0, 210, 255, 0.2);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    display: inline-block;
}

/* ─── Empty State ─── */
.empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
}

.empty-state i {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.4;
}

/* ─── Toast / Notification Overrides ─── */
#toast-container > .toast {
    background-image: none !important;
    border-radius: 10px;
}

.toast-success {
    background-color: var(--success-green) !important;
}

.toast-error {
    background-color: var(--error-red) !important;
}

/* ─── TempData Alert Banners ─── */
.alert-banner {
    border: none;
    border-radius: 10px;
    padding: 0.8rem 1.2rem;
    font-weight: 600;
    font-size: 0.88rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    animation: slideDown 0.4s ease;
}

.alert-banner-success {
    background: rgba(16, 185, 129, 0.12);
    color: var(--success-green);
    border: 1px solid rgba(16, 185, 129, 0.2);
}

.alert-banner-error {
    background: rgba(255, 77, 109, 0.12);
    color: var(--error-red);
    border: 1px solid rgba(255, 77, 109, 0.2);
}

@keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ─── Smooth Scroll & Transitions ─── */
html {
    scroll-behavior: smooth;
}

/* ─── Responsive Tweaks ─── */
@media (max-width: 768px) {
    .glass-card {
        padding: 1.5rem;
        border-radius: 14px;
    }

    .page-heading {
        font-size: 1.3rem;
        letter-spacing: 2px;
    }
}
