:root {
    --bg-main: #0f111a;
    --card-bg: #1a1d29;
    --row-alt: #222636;
    --accent-blue: #00d2ff;
    --text-primary: #ffffff;
    --text-muted: #a0aec0;
    --error-red: #ff4d4d;
}

body {
    background-color: var(--bg-main);
    color: var(--text-primary);
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 0;
}

/* Glassmorphism Card Container */
.glass-card {
    background: var(--card-bg);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    padding: 2.5rem;
    margin-top: 2rem;
    margin-bottom: 2rem;
}

/* Professional Form Controls */
.form-control, .form-select {
    background: #2d3245;
    border: 1px solid #3f445e;
    color: #fff !important;
    border-radius: 8px;
    transition: all 0.3s ease;
}

    .form-control:focus, .form-select:focus {
        background: #343a52;
        border-color: var(--accent-blue);
        box-shadow: 0 0 8px rgba(0, 210, 255, 0.3);
        outline: none;
    }

/* Validation Message Styling */
.text-danger {
    color: var(--error-red) !important;
    font-size: 0.85rem;
    font-weight: 500;
}

/* Button Styling with Gradient */
.btn-grad {
    background: linear-gradient(90deg, #00d2ff 0%, #3a7bd5 100%);
    border: none;
    color: white !important;
    font-weight: 600;
    transition: 0.3s;
    border-radius: 8px;
    padding: 10px 25px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

    .btn-grad:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 210, 255, 0.4);
        filter: brightness(1.1);
    }

/* Table: Professional Dashboard Layout */
.table-custom {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 10px; /* Space between the "row blocks" */
}

    .table-custom thead th {
        color: var(--text-muted);
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        padding: 12px 20px;
        border: none;
    }

    .table-custom tbody td {
        padding: 15px 20px;
        vertical-align: middle;
        border: none;
    }

    /* Alternating Row Logic */
    /* Row 1, 3, 5... (Odd) */
    .table-custom tbody tr:nth-child(odd) {
        background-color: var(--card-bg);
    }

    /* Row 2, 4, 6... (Even) */
    .table-custom tbody tr:nth-child(even) {
        background-color: var(--row-alt);
    }

    /* Hover & Interactive Logic */
    .table-custom tbody tr {
        transition: transform 0.2s ease, filter 0.2s ease, border-left 0.2s ease;
        border-left: 4px solid transparent;
    }

        .table-custom tbody tr:hover {
            filter: brightness(1.25);
            border-left: 4px solid var(--accent-blue);
            cursor: pointer;
            transform: translateX(5px); /* Slight slide to the right */
        }

/* Custom UI Elements */
.badge-course {
    background: rgba(0, 210, 255, 0.1);
    color: var(--accent-blue);
    border: 1px solid rgba(0, 210, 255, 0.3);
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
}

/* Toastr Notification Overrides (If using Toastr) */
#toast-container > .toast {
    background-image: none !important;
}

.toast-success {
    background-color: #28a745 !important;
}

.toast-error {
    background-color: #dc3545 !important;
}
