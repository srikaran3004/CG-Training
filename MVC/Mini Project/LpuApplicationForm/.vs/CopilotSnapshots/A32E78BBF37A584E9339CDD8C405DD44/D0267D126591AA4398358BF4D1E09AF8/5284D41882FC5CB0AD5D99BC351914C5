@model IEnumerable<LpuApplicationForm.Models.StudentModel>

<div class="container-fluid px-4">
    <div class="glass-card mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert-banner alert-banner-success mb-3">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-banner alert-banner-error mb-3">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="fw-bold page-heading mb-0">ADMISSION RECORDS</h2>
                <p class="mb-0" style="color: var(--text-secondary); font-size: 0.78rem;">
                    <i class="bi bi-people-fill me-1" style="color: var(--brand-orange);"></i>@Model.Count() total application(s)
                </p>
            </div>
            <a asp-action="Create" class="btn btn-grad">
                <i class="bi bi-plus-circle-fill me-1"></i>NEW APPLICATION
            </a>
        </div>

        <div class="table-responsive">
            @if (Model.Any())
            {
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Course</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (item.ProfileImage != null && item.ImageExtension != null)
                                    {
                                        <img src="data:image/@item.ImageExtension.TrimStart('.');base64,@Convert.ToBase64String(item.ProfileImage)"
                                             class="table-avatar" alt="Photo" />
                                    }
                                    else
                                    {
                                        <div class="table-avatar-placeholder">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold">@item.FullName</td>
                                <td style="color: var(--brand-orange);">@item.Email</td>
                                <td>@item.Mobile</td>
                                <td>
                                    <span class="badge-course">@item.CourseApplied</span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.StudentId"
                                       class="btn btn-sm btn-action-edit me-1" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.StudentId"
                                       class="btn btn-sm btn-action-delete"
                                       onclick="return confirm('Are you sure you want to delete this record?')" title="Delete">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h5>No Applications Yet</h5>
                    <p style="font-size: 0.9rem;">Click "New Application" to create the first admission entry.</p>
                </div>
            }
        </div>
    </div>
</div>