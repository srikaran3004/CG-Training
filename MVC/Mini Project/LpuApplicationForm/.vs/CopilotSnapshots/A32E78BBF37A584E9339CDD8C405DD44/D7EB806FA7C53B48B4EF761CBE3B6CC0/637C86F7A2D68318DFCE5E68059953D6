@model LpuApplicationForm.Models.StudentModel

@{
    ViewData["Title"] = Model?.StudentId > 0 ? "Edit Application" : "LPU Admission Form";
    var isEdit = Model?.StudentId > 0;
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="glass-card">
                <h2 class="text-center mb-1 page-heading">
                    @(isEdit ? "EDIT APPLICATION" : "LPU ADMISSION FORM")
                </h2>
                <p class="text-center mb-3" style="color: var(--text-muted); font-size: 0.82rem;">
                    @(isEdit ? "Update the student details below" : "Fill in the details to apply for admission")
                </p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert-banner alert-banner-success mb-2">
                        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert-banner alert-banner-error mb-2">
                        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                    </div>
                }

                <div asp-validation-summary="All" class="text-danger mb-2 fw-bold"></div>

                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="StudentId" />

                    <!-- Personal Information -->
                    <div class="form-section-title">
                        <i class="bi bi-person-fill"></i> Personal Information
                    </div>
                    <div class="row g-2 mb-1">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="john@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row g-2 mb-1">
                        <div class="col-md-4">
                            <label asp-for="Mobile" class="form-label">Mobile</label>
                            <input asp-for="Mobile" class="form-control" placeholder="10-digit number" />
                            <span asp-validation-for="Mobile" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Gender" class="form-label">Gender</label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DOB" class="form-label">Date of Birth</label>
                            <input asp-for="DOB" class="form-control" type="date" />
                            <span asp-validation-for="DOB" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="section-divider">

                    <!-- Address Details -->
                    <div class="form-section-title">
                        <i class="bi bi-geo-alt-fill"></i> Address Details
                    </div>
                    <div class="row g-2 mb-1">
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">Address</label>
                            <textarea asp-for="Address" class="form-control" rows="2" placeholder="Full street address (min 10 chars)"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row g-2 mb-1">
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label">City</label>
                            <input asp-for="City" class="form-control" placeholder="Enter city" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="State" class="form-label">State</label>
                            <input asp-for="State" class="form-control" placeholder="Enter state" />
                            <span asp-validation-for="State" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Pincode" class="form-label">Pincode</label>
                            <input asp-for="Pincode" class="form-control" placeholder="6-digit pincode" />
                            <span asp-validation-for="Pincode" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="section-divider">

                    <!-- Academic Details -->
                    <div class="form-section-title">
                        <i class="bi bi-mortarboard-fill"></i> Academic Details
                    </div>
                    <div class="row g-2 mb-1">
                        <div class="col-md-4">
                            <label asp-for="HighSchoolMarks" class="form-label">10th Marks (%)</label>
                            <input asp-for="HighSchoolMarks" class="form-control" type="number" step="0.01" placeholder="0 - 100" />
                            <span asp-validation-for="HighSchoolMarks" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IntermediateMarks" class="form-label">12th Marks (%)</label>
                            <input asp-for="IntermediateMarks" class="form-control" type="number" step="0.01" placeholder="0 - 100" />
                            <span asp-validation-for="IntermediateMarks" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CourseApplied" class="form-label">Course</label>
                            <select asp-for="CourseApplied" class="form-select">
                                <option value="">-- Choose Course --</option>
                                <option value="B.Tech CSE">B.Tech CSE</option>
                                <option value="MBA">MBA</option>
                                <option value="BCA">BCA</option>
                                <option value="M.Tech">M.Tech</option>
                                <option value="B.Com">B.Com</option>
                            </select>
                            <span asp-validation-for="CourseApplied" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="text-center mt-3">
                        <button type="submit" class="btn btn-grad">
                            <i class="bi bi-send-fill me-1"></i>@(isEdit ? "UPDATE" : "SUBMIT APPLICATION")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-light ms-2">
                            <i class="bi bi-arrow-left me-1"></i>BACK TO LIST
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}