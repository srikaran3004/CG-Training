<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LPU Admissions</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body, .form-control, .form-select, .btn { font-family: 'Inter', system-ui, -apple-system, sans-serif; }

        .navbar-custom {
            background: rgba(10, 12, 21, 0.92) !important;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding: 0.45rem 0;
        }

        .nav-link {
            color: rgba(255,255,255,0.55) !important;
            transition: all 0.25s ease;
            font-weight: 500;
            font-size: 0.82rem;
            padding: 0.4rem 0.8rem !important;
            border-radius: 6px;
            margin: 0 2px;
        }

        .nav-link:hover {
            color: #fff !important;
            background: rgba(0, 198, 251, 0.07);
        }

        .nav-link i { margin-right: 5px; font-size: 0.78rem; }

        .navbar-brand {
            color: #fff !important;
            font-weight: 800;
            letter-spacing: 1.5px;
            font-size: 1.05rem;
        }

        .navbar-brand .brand-accent {
            background: linear-gradient(135deg, #00c6fb, #6f5cff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        footer {
            background: rgba(0, 0, 0, 0.25);
            backdrop-filter: blur(8px);
            color: rgba(255,255,255,0.3) !important;
            border-top: 1px solid rgba(255, 255, 255, 0.03);
            font-size: 0.78rem;
        }

        footer a {
            color: var(--accent-blue) !important;
            text-decoration: none;
            transition: opacity 0.2s;
        }
        footer a:hover { opacity: 0.7; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Student" asp-action="Index">
                    <span class="brand-accent">LPU</span> PORTAL
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill"></i>Applications
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Create">
                                <i class="bi bi-plus-circle-fill"></i>New Entry
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-auto py-3">
        <div class="container text-center">
            &copy; 2026 - LPU Admission Portal - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-info">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>