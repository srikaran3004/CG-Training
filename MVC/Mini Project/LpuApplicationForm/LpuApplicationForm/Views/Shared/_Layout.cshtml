<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LPU Admissions</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body, .form-control, .form-select, .btn { font-family: 'Poppins', system-ui, -apple-system, sans-serif; }

        /* ─── Navbar (Black #1A1A1A) ─── */
        .navbar-custom {
            background: #1A1A1A !important;
            border-bottom: 3px solid #F47C00;
            padding: 0.5rem 0;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.65) !important;
            transition: all 0.3s ease;
            font-weight: 500;
            font-size: 0.82rem;
            padding: 0.4rem 0.9rem !important;
            border-radius: 6px;
            margin: 0 2px;
            position: relative;
        }

        .nav-link:hover,
        .nav-link.active {
            color: #fff !important;
            background: rgba(244, 124, 0, 0.1);
        }

        .nav-link.active::after,
        .nav-link:hover::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            transform: translateX(-50%);
            width: 60%;
            height: 2px;
            background: #F47C00;
            border-radius: 2px;
        }

        .nav-link i { margin-right: 5px; font-size: 0.78rem; }

        .navbar-brand {
            color: #fff !important;
            font-weight: 700;
            letter-spacing: 1.5px;
            font-size: 1.05rem;
        }

        .navbar-brand .brand-accent {
            color: #F47C00;
        }

        /* ─── Footer ─── */
        footer {
            background: #1A1A1A;
            color: rgba(255, 255, 255, 0.5) !important;
            border-top: 2px solid #F47C00;
            font-size: 0.78rem;
        }

        footer a {
            color: #F47C00 !important;
            text-decoration: none;
            transition: opacity 0.3s;
        }
        footer a:hover { opacity: 0.7; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Student" asp-action="Index">
                    <span class="brand-accent">LPU</span> PORTAL
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill"></i>Applications
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Create">
                                <i class="bi bi-plus-circle-fill"></i>New Entry
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-auto py-3">
        <div class="container text-center">
            &copy; 2026 - LPU Admission Portal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>